# Copy to backend/.env and fill in real values. Never commit the real .env.

# Google Gemma via the Gen AI SDK (https://ai.google.dev/)
GOOGLE_API_KEY=your-google-ai-api-key

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Anon (publishable) key is fine for local dev; FastAPI also reads/writes
# under permissive RLS policies defined in supabase/schema.sql.
SUPABASE_KEY=eyJhbGciOi...your-anon-jwt
